# Copy this file to `.env` and fill in the values from your Supabase project.
# These are the SAME values used by the existing React app
# (React names: VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY).
#
# IMPORTANT: Use the publishable / anon key ONLY. Never put the service_role key here.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-publishable-key
